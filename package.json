{
  "name": "brs-js",
  "version": "3.0.1",
  "description": "Brickadia Save Read/Writing",
  "main": "index.js",
  "browser": "dist/dist.web.js",
  "module": "dist/dist.mjs",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "browser": "./dist/dist.web.js",
      "import": "./dist/dist.mjs",
      "require": "./index.js",
      "default": "./dist/dist.mjs"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "watch": "vite build --watch",
    "dist": "vite build && tsc --emitDeclarationOnly",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meshiest/brs-js.git"
  },
  "keywords": [
    "brs",
    "brickadia",
    "save",
    "file",
    "format"
  ],
  "author": "Meshiest <gpg@reheatedcake.io>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/meshiest/brs-js/issues"
  },
  "homepage": "https://github.com/meshiest/brs-js#readme",
  "dependencies": {
    "detect-node": "^2.0.4"
  },
  "peerDependencies": {
    "better-sqlite3": ">=7.5.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "types": "./dist/src/index.d.ts",
  "devDependencies": {
    "@noble/hashes": "^2.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/pako": "^2.0.4",
    "better-sqlite3": "^12.11.1",
    "fzstd": "^0.1.1",
    "pako": "^3.0.0",
    "prettier": "^2.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}